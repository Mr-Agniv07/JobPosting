# ── MongoDB ────────────────────────────────────────────────
# A free MongoDB Atlas cluster works. Can be the same cluster as ResumeForge
# (use a separate DB name, e.g. ...mongodb.net/fresherjobs) or a brand new one.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/fresherjobs

# ── Server ─────────────────────────────────────────────────
PORT=4000

# ── ResumeForge funnel ─────────────────────────────────────
# PUBLIC URL where the ResumeForge builder (index.html) is served — NOT the API.
# Every "Build a resume for this job" button deep-links here with the JD preloaded.
RESUMEFORGE_URL=https://your-resumeforge-frontend-url

# ── Sources (India-focused; verified to return jobs) ───────
# Comma-separated company board tokens for each ATS. Add more over time.
#   Greenhouse: boards.greenhouse.io/<token>
#   Lever:      jobs.lever.co/<token>
#   Ashby:      jobs.ashbyhq.com/<token>
GREENHOUSE_BOARDS=groww,phonepe,postman,slice,druva
LEVER_BOARDS=paytm,cred,meesho,zeta,mindtickle,porter,fi,fampay,hevodata
ASHBY_BOARDS=scaler,atlan

# ── Adzuna aggregator (optional, biggest India volume) ─────
# Indexes the whole India job market — hundreds of fresher roles, not just
# ATS startups. Free key: https://developer.adzuna.com → register → create an app,
# then copy the Application ID and Application Key below. Leave blank to disable.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
ADZUNA_QUERIES=fresher,graduate trainee,entry level,junior,intern
ADZUNA_PAGES=2

# How often to re-pull sources (cron expression). Default: every 3 hours.
SCRAPE_CRON=0 */3 * * *
